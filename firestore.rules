rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check permissions
    function hasPermission(permission) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // Assuming roles are stored in 'roles' collection and have a 'permissions' array
      // This also assumes the user document has a 'role' field matching a document ID in 'roles'
      // For simple string roles in user doc, we might need a different approach or map them here.
      // Since the app uses a 'roles' collection, we can fetch it.
      let roleData = get(/databases/$(database)/documents/roles/$(user.role)).data;
      return roleData.isAdmin == true || permission in roleData.permissions;
    }

    match /client_strategies/{strategy} {
      allow read: if hasPermission('clients.view');
      allow write: if hasPermission('clients.manage') || hasPermission('clients.manage_strategies');
    }

    match /client_monthly_reports/{report} {
      allow read: if hasPermission('clients.view');
      allow write: if hasPermission('clients.manage') || hasPermission('client.reports.create');
      allow delete: if hasPermission('clients.manage') || hasPermission('client.reports.delete');
    }

    // Notification rules
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      // Only authenticated users and system can write notifications
      allow create: if request.auth != null;
      // Users can update their own notifications (mark as read, etc.)
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      // Users can delete their own notifications
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Notification preferences rules
    match /notification_preferences/{userId} {
      // Users can only read and write their own preferences
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Notification outbox (for Cloud Function processing)
    match /notifications_outbox/{docId} {
      // Only authenticated users can create outbox entries
      allow create: if request.auth != null;
      // Cloud Function needs to read and delete
      allow read, delete: if true;
    }

    // Notification tokens
    match /notification_tokens/{tokenId} {
      // Users can manage their own tokens
      allow read, write: if request.auth != null && 
        (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null;
      // Cloud Function needs to delete invalid tokens
      allow delete: if true;
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
