rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────────
    //  HELPER FUNCTIONS
    // ──────────────────────────────────────────────────

    // Get the current user's document data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Get the role document for the current user via roleId
    // roleId is stored on the user document (e.g. "r1", "r2", etc.)
    function getRoleData() {
      let user = getUserData();
      return get(/databases/$(database)/documents/roles/$(user.roleId)).data;
    }

    // Check if the current user is an admin
    function isAdmin() {
      return request.auth != null && getRoleData().isAdmin == true;
    }

    // Check if the current user has a specific permission
    function hasPermission(permission) {
      let roleData = getRoleData();
      return roleData.isAdmin == true || permission in roleData.permissions;
    }

    // Shorthand: authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the requesting user owns this resource
    function isOwner(field) {
      return request.auth.uid == resource.data[field];
    }

    // ──────────────────────────────────────────────────
    //  SENSITIVE COLLECTIONS — tightly scoped
    // ──────────────────────────────────────────────────

    // Users collection — self-read, admin-write for role changes
    match /users/{userId} {
      // Any authenticated user can read any user (needed for team lists, mentions, etc.)
      allow read: if isAuthenticated();
      // Users can update their own profile (non-role fields)
      // Admin can update any user (including role assignment)
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Only admin can create or delete user documents
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Roles collection — read for all authenticated, write only for admin
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Audit logs — append-only, immutable, admin can read
    match /audit_logs/{logId} {
      // All authenticated users can read audit logs (for transparency)
      // If you want to restrict: change to isAdmin()
      allow read: if isAuthenticated();
      // Any authenticated user can create logs (actions are logged from client)
      allow create: if isAuthenticated();
      // Audit logs are immutable — no updates or deletes
      allow update, delete: if false;
    }

    // Settings — read for all authenticated, write only for admin
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Departments — read for all authenticated, write only for admin
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Dashboard banners — read for all, write only for admin
    match /dashboard_banners/{bannerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────────────────
    //  NOTIFICATION COLLECTIONS — user-scoped
    // ──────────────────────────────────────────────────

    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      // Any authenticated user can create notifications (for mentions, assignments, etc.)
      allow create: if isAuthenticated();
      // Users can update their own notifications (mark as read, etc.)
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      // Users can delete their own notifications
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Notification preferences — user-scoped
    match /notification_preferences/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Notification outbox — for Cloud Function processing
    match /notifications_outbox/{docId} {
      allow create: if isAuthenticated();
      // Cloud Functions use Admin SDK (bypasses rules). Only admins can read for debugging.
      allow read: if isAdmin();
      // Only admin/system should clean up outbox
      allow delete: if isAdmin();
    }

    // Notification tokens — user-scoped
    match /notification_tokens/{tokenId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.uid);
      // Users can delete their own tokens, admin can clean up stale tokens
      allow delete: if isAuthenticated() &&
        (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.uid || isAdmin());
    }

    // ──────────────────────────────────────────────────
    //  BUSINESS DATA — permission-enforced access
    //  Firestore rules now mirror the application-layer
    //  RBAC via hasPermission() for write operations.
    //  Read is auth-gated; write requires specific permissions.
    // ──────────────────────────────────────────────────

    // Client data collections
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('clients.create');
      allow update: if isAuthenticated() && hasPermission('clients.edit');
      allow delete: if isAuthenticated() && hasPermission('clients.delete');
    }
    match /client_strategies/{strategyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('clients.edit');
    }
    match /client_monthly_reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('clients.edit');
    }
    match /client_brand_assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('clients.edit');
    }
    match /client_meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('clients.edit');
      allow update: if isAuthenticated() && hasPermission('clients.edit');
      allow delete: if isAuthenticated() && hasPermission('clients.delete');
    }
    match /client_notes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && hasPermission('clients.delete');
    }
    match /client_social_links/{linkId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('clients.edit');
    }
    match /client_approvals/{approvalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Project collections
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('projects.create');
      allow update: if isAuthenticated() && hasPermission('projects.edit');
      allow delete: if isAuthenticated() && hasPermission('projects.delete');
    }
    match /project_members/{memberId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('projects.edit');
    }
    match /project_milestones/{milestoneId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('projects.edit');
    }
    match /project_activity_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Activity logs are immutable
    }
    match /project_marketing_assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('projects.edit');
    }

    // Task collections
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('tasks.create');
      allow update: if isAuthenticated() && hasPermission('tasks.edit');
      allow delete: if isAuthenticated() && hasPermission('tasks.delete');
    }
    match /task_comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }
    match /task_activity_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Activity logs are immutable
    }
    match /task_dependencies/{depId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('tasks.edit');
    }
    match /task_time_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && hasPermission('tasks.delete');
    }
    match /task_qc_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Calendar collections
    match /calendar_items/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('calendar.items.create');
      allow update: if isAuthenticated() && hasPermission('calendar.items.edit');
      allow delete: if isAuthenticated() && hasPermission('calendar.items.delete');
    }
    match /calendar_months/{monthId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('calendar.months.edit');
    }
    match /calendar_item_revisions/{revisionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Revisions are immutable
    }

    // Creative direction collections
    match /creative_projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('creative.manage');
      allow update: if isAuthenticated() && hasPermission('creative.manage');
      allow delete: if isAuthenticated() && hasPermission('creative.manage');
    }
    match /creative_calendars/{calendarId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('creative.manage');
    }
    match /creative_calendar_items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('creative.manage');
    }

    // Production collections
    match /production_plans/{planId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('production.create');
      allow update: if isAuthenticated() && hasPermission('production.edit');
      allow delete: if isAuthenticated() && hasPermission('production.delete');
    }
    match /production_assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('production.edit');
    }
    match /production_assets/{assetId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('production.create');
      allow update: if isAuthenticated() && hasPermission('production.edit');
      allow delete: if isAuthenticated() && hasPermission('production.delete');
    }
    match /call_sheets/{sheetId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('production.edit');
    }
    match /shot_lists/{listId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('production.edit');
    }

    // Workflow & approval collections
    match /workflow_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('workflows.manage');
    }
    match /approval_steps/{stepId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Social & posting collections
    match /social_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('posting.create');
      allow update: if isAuthenticated() && hasPermission('posting.edit');
      allow delete: if isAuthenticated() && hasPermission('posting.delete');
    }
    match /milestones/{milestoneId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('projects.edit');
    }

    // File management
    match /files/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('assets.upload');
      allow update: if isAuthenticated() && hasPermission('assets.edit_metadata');
      allow delete: if isAuthenticated() && hasPermission('assets.delete');
    }
    match /folders/{folderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('assets.upload');
      allow update: if isAuthenticated() && hasPermission('assets.edit_metadata');
      allow delete: if isAuthenticated() && hasPermission('assets.delete');
    }

    // Presentation sharing
    match /presentation_shares/{shareId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Finance collections
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('finance.create_invoice');
      allow update: if isAuthenticated() && hasPermission('finance.edit_invoice');
      allow delete: if isAuthenticated() && hasPermission('finance.delete_invoice');
    }

    // Vendor collections
    match /vendors/{vendorId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('vendors.create');
      allow update: if isAuthenticated() && hasPermission('vendors.edit');
      allow delete: if isAuthenticated() && hasPermission('vendors.delete');
    }
    match /vendor_service_orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('vendors.edit');
      allow update: if isAuthenticated() && hasPermission('vendors.edit');
      allow delete: if isAuthenticated() && hasPermission('vendors.delete');
    }

    // HR collections
    match /freelancer_assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('production.edit');
    }

    // HR Module — Employee Profiles (sensitive — read restricted)
    match /employee_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('hr.employees.create');
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        hasPermission('hr.employees.edit')
      );
      allow delete: if isAdmin();
    }

    // HR Module — Teams
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('hr.org.manage');
    }

    // HR Module — Leave Requests (own-read + managers + HR)
    match /leave_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('hr.leave.create');
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        hasPermission('hr.leave.approve') ||
        hasPermission('hr.leave.reject') ||
        hasPermission('hr.leave.cancel')
      );
      allow delete: if isAdmin();
    }

    // HR Module — Leave Policies (admin-managed)
    match /leave_policies/{policyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // HR Module — Leave Balances (own-read + HR-write)
    match /leave_balances/{balanceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        hasPermission('hr.leave.approve') ||
        isAdmin()
      );
    }

    // HR Module — Attendance Records
    match /attendance_records/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.userId ||
        hasPermission('hr.attendance.manage')
      );
      allow delete: if isAdmin();
    }

    // HR Module — Attendance Corrections
    match /attendance_corrections/{correctionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && hasPermission('hr.attendance.manage');
      allow delete: if isAdmin();
    }

    // HR Module — Onboarding Checklists
    match /onboarding_checklists/{checklistId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('hr.onboarding.manage');
    }

    // HR Module — Offboarding Checklists
    match /offboarding_checklists/{checklistId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('hr.offboarding.manage');
    }

    // HR Module — Employee Assets
    match /employee_assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('hr.assets.manage');
    }

    // HR Module — Performance Reviews
    match /performance_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasPermission('hr.performance.manage');
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.employeeId ||
        request.auth.uid == resource.data.reviewerId ||
        hasPermission('hr.performance.manage')
      );
      allow delete: if isAdmin();
    }

    // HR Module — Employee Status Changes (append-only audit trail)
    match /employee_status_changes/{changeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Equipment & locations
    match /agency_equipment/{equipmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('admin.settings.edit');
    }
    match /agency_locations/{locationId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && hasPermission('admin.settings.edit');
    }

    // Branding collection
    match /branding/{brandingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Notes collection
    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────────────────
    //  DEFAULT CATCH-ALL — DENY ALL
    //  Any collection not explicitly matched above is
    //  completely inaccessible. This prevents accidental
    //  data exposure from future collections.
    // ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
