{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,

    /* Strict-mode migration — enabled incrementally.
     * These flags add ZERO new errors as of March 2026.
     * Enable more flags as errors are resolved. */
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true
    /* TODO: Enable once 46 errors are resolved:
     * "strictNullChecks": true
     * Then: "noImplicitAny": true (adds ~20 more)
     * Finally: "strict": true (umbrella flag)
     */
  }
}