# Local overrides (optional — loaded for ALL modes, overrides .env.development/.env.production)
# Only create .env.local if you need to override specific values locally.
# For normal development, .env.development has everything you need.
#
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_VAPID_KEY=your_vapid_key
# VITE_GEMINI_API_KEY=your_gemini_key
# VITE_ENVIRONMENT=development
